# ─────────────────────────────────────────────────────────────────────────────
# Meta / Facebook Graph API
# ─────────────────────────────────────────────────────────────────────────────

# Long-lived User or System User access token from Meta Business Manager.
# Required for all pipelines.
META_ACCESS_TOKEN=your_meta_access_token_here

# API version to use. Keep in sync with the version your token was issued for.
META_API_VERSION=v25.0

# Comma-separated list of ad account IDs (with or without the act_ prefix).
# Example: META_AD_ACCOUNT_IDS=act_123456789,act_987654321
META_AD_ACCOUNT_IDS=act_your_account_id_here

# ── Multi-profile account lists (optional) ────────────────────────────────────
# Define named groups of accounts. Use --profile <name> on the CLI to target
# a specific group. Profile names are case-insensitive.
# META_AD_ACCOUNT_IDS_AGENCY=act_111,act_222
# META_AD_ACCOUNT_IDS_CLIENT=act_333,act_444


# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────────────────────────────────────

# Full SQLAlchemy connection string.
# Format: postgresql://user:password@host:port/database
DB_CONN_STRING=postgresql://postgres:yourpassword@localhost:5432/ads_db

# ── Multi-profile DB connections (optional) ───────────────────────────────────
# DB_CONN_STRING_AGENCY=postgresql://user:pass@host:5432/agency_db
# DB_CONN_STRING_CLIENT=postgresql://user:pass@host:5432/client_db


# ─────────────────────────────────────────────────────────────────────────────
# BigQuery  (only required for --to-bigquery / sync-to-bigquery commands)
# ─────────────────────────────────────────────────────────────────────────────

# GCP project ID where the BigQuery dataset lives.
BQ_PROJECT_ID=your-gcp-project-id

# BigQuery dataset name (will be created if it doesn't exist).
BQ_DATASET=meta_ads

# Dataset location (e.g. US, EU, europe-west1).
BQ_LOCATION=US

# Path to a GCP service account JSON key file.
# Leave blank to use Application Default Credentials (gcloud auth).
BQ_CREDENTIALS_PATH=credentials/bigquery-service-account.json

# Service account to impersonate (optional, leave blank if not using impersonation).
# BQ_IMPERSONATE_SERVICE_ACCOUNT=

# ── Multi-profile BigQuery settings (optional) ────────────────────────────────
# BQ_PROJECT_ID_AGENCY=agency-gcp-project
# BQ_DATASET_AGENCY=meta_ads_agency
# BQ_LOCATION_AGENCY=EU
# BQ_CREDENTIALS_PATH_AGENCY=credentials/agency-service-account.json
